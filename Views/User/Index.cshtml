@model IEnumerable<qlgiaidau.Models.User>

<h2>Danh sách người dùng</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Role</th>
            <th>PasswordHash</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user.Id</td>
            <td>@user.Role</td>
            <td>@user.PasswordHash</td>
            <td>
                <!-- Viewer chỉ xem, Admin mới thấy nút Sửa/Xóa -->
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Xóa</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

<!-- Nút thêm người dùng: chỉ Admin mới thấy -->
@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-success">Thêm người dùng</a>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}