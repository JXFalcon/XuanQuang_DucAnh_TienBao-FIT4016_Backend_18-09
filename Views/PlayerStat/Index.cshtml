@model IEnumerable<qlgiaidau.Models.PlayerStat>

@{
    ViewData["Title"] = "Thống kê cầu thủ";
}

<h2>Thống kê cầu thủ</h2>

<!-- Nút thêm thống kê: chỉ Admin và Coach mới thấy -->
@if (User.IsInRole("Admin") || User.IsInRole("Coach"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">Thêm thống kê cầu thủ</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Tên cầu thủ</th>
            <th>Bàn thắng</th>
            <th>Kiến tạo</th>
            <th>Đội bóng</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var player in Model)
    {
        <tr>
            <td>@player.PlayerName</td>
            <td>@player.Goals</td>
            <td>@player.Assists</td>
            <td>@player.Team?.Name</td>
            <td>
                <!-- Viewer, Admin, Coach đều xem chi tiết -->
                <a asp-action="Details" asp-route-id="@player.Id" class="btn btn-info btn-sm">Chi tiết</a>

                <!-- Chỉ Admin mới thấy nút Sửa/Xóa -->
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@player.Id" class="btn btn-warning btn-sm">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@player.Id" class="btn btn-danger btn-sm">Xóa</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}