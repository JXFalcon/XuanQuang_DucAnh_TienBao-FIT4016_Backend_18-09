@model IEnumerable<qlgiaidau.Models.Notification>

<h2>Thông báo</h2>

<!-- Nút thêm thông báo: chỉ Admin mới thấy -->
@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-success mb-3">Thêm thông báo</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Tiêu đề</th>
            <th>Nội dung</th>
            <th>Ngày tạo</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var noti in Model)
    {
        <tr>
            <td>@noti.Id</td>
            <td>@noti.Title</td>
            <td>@noti.Message</td>
            <td>@noti.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
            <td>
                <!-- Viewer và Admin đều xem chi tiết -->
                <a asp-action="Details" asp-route-id="@noti.Id" class="btn btn-sm btn-info">Chi tiết</a>

                <!-- Chỉ Admin mới thấy nút Sửa/Xóa -->
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@noti.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@noti.Id" class="btn btn-sm btn-danger">Xóa</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}