@model IEnumerable<qlgiaidau.Models.Match>

<h2>Danh sách trận đấu</h2>

<!-- Nút thêm trận đấu: chỉ Admin mới thấy -->
@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-success mb-3">Thêm trận đấu</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Team A</th>
            <th>Team B</th>
            <th>Ngày thi đấu</th>
            <th>Địa điểm</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var match in Model)
    {
        <tr>
            <td>@match.Id</td>
            <td>@match.TeamA?.Name</td>
            <td>@match.TeamB?.Name</td>
            <td>@match.MatchDate.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@match.Location</td>
            <td>
                <!-- Viewer và Admin đều xem chi tiết -->
                <a asp-action="Details" asp-route-id="@match.Id" class="btn btn-sm btn-info">Chi tiết</a>

                <!-- Chỉ Admin mới thấy nút Sửa/Xóa -->
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@match.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@match.Id" class="btn btn-sm btn-danger">Xóa</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}