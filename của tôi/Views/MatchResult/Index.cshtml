@model IEnumerable<qlgiaidau.Models.MatchResult>

<link rel="stylesheet" href="~/css/matchresult.css" />

<h2>Kết quả trận đấu</h2>

<!-- Nút thêm kết quả: chỉ Admin mới thấy -->
@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-success mb-3">Thêm kết quả</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Team A</th>
            <th>Team B</th>
            <th>Tỉ số Đội A</th>
            <th>Tỉ số Đội B</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var result in Model)
    {
        <tr>
            <td>@result.Match?.TeamA?.Name</td>
            <td>@result.Match?.TeamB?.Name</td>
            <td><span class="score-badge">@result.TeamAScore</span></td>
            <td><span class="score-badge">@result.TeamBScore</span></td>
            <td>
                <!-- Viewer và Admin đều xem chi tiết -->
                <a asp-action="Details" asp-route-id="@result.Id" class="btn btn-sm btn-info">Chi tiết</a>

                <!-- Chỉ Admin mới thấy nút Sửa/Xóa -->
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@result.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@result.Id" class="btn btn-sm btn-danger">Xóa</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}