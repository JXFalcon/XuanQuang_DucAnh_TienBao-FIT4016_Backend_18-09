@model List<Team>
@{
    ViewData["Title"] = "Danh sách đội bóng";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<h2 class="mt-3">🏆 Danh sách đội bóng</h2>

<!-- Nút thêm đội mới: chỉ Admin mới thấy -->
@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">Thêm đội mới</a>
}

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Tên</th>
            <th>Logo</th>
            <th>Mô tả</th>
            <th>Thắng</th>
            <th>Thua</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var team in Model)
        {
            <tr>
                <td>@team.Name</td>
                <td><img src="~/images/@team.LogoUrl" alt="@team.Name" width="50" /></td>
                <td>@team.Description</td>
                <td>@team.Wins</td>
                <td>@team.Losses</td>
                <td>
                    <!-- Viewer và Admin đều xem chi tiết -->
                    <a asp-action="Details" asp-route-id="@team.Id" class="btn btn-info btn-sm">Chi tiết</a>

                    <!-- Chỉ Admin mới thấy nút Sửa/Xóa -->
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@team.Id" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@team.Id" class="btn btn-danger btn-sm">Xóa</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}