<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Quản lý bóng đá</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">QL Giải Đấu</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNav" aria-controls="navbarNav"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                @if (User.Identity.IsAuthenticated)
                {
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Team" asp-action="Index">Đội bóng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Match" asp-action="Index">Trận đấu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="MatchResult" asp-action="Index">Kết quả</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="PlayerStat" asp-action="Index">Thống kê cầu thủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Notification" asp-action="Index">Thông báo</a>
                        </li>

                        @* Chỉ Admin mới thấy mục Người dùng *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="User" asp-action="Index">Người dùng</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </nav>

    <div class="container mt-3">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>