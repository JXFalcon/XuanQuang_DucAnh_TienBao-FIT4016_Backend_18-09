@model SportsTournamentManager.Models.Team

<h2>Tạo đội mới</h2>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Country"></label>
        <input asp-for="Country" class="form-control" />
    </div>

    <!-- Coach để trống cũng được -->
    <div class="form-group">
        <label asp-for="Coach.Name"></label>
        <input asp-for="Coach.Name" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Coach.Nationality"></label>
        <input asp-for="Coach.Nationality" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>