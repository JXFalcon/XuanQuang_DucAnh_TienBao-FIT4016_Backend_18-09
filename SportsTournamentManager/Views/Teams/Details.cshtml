@model SportsTournamentManager.Models.Team

<h2>Chi tiết đội</h2>

<dl class="row">
    <dt class="col-sm-2">Tên đội</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Quốc gia</dt>
    <dd class="col-sm-10">@Model.Country</dd>

    <dt class="col-sm-2">Huấn luyện viên</dt>
    <dd class="col-sm-10">@Model.Coach?.Name (@Model.Coach?.Nationality)</dd>
</dl>

<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a> |
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</p>