@model SportsTournamentManager.Models.Venue

<h2>Chi tiết địa điểm</h2>

<dl class="row">
    <dt class="col-sm-2">Tên</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Địa chỉ</dt>
    <dd class="col-sm-10">@Model.Location</dd>

    <dt class="col-sm-2">Sức chứa</dt>
    <dd class="col-sm-10">@Model.Capacity</dd>
</dl>

<h4>Danh sách giải đấu tổ chức tại đây</h4>
<ul>
@foreach (var t in Model.Tournaments)
{
    <li>@t.Name (@t.StartDate.ToString("dd/MM/yyyy") - @t.EndDate.ToString("dd/MM/yyyy"))</li>
}
</ul>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Sửa</a>
<a asp-action="Index" class="btn btn-secondary">Quay lại</a>