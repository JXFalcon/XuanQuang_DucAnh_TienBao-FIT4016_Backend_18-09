@model SportsTournamentManager.Models.Venue

<h2>Xóa địa điểm</h2>

<h4>Bạn có chắc muốn xóa địa điểm này?</h4>
<hr />

<dl class="row">
    <dt class="col-sm-2">Tên</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Địa chỉ</dt>
    <dd class="col-sm-10">@Model.Location</dd>

    <dt class="col-sm-2">Sức chứa</dt>
    <dd class="col-sm-10">@Model.Capacity</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>