@model SportsTournamentManager.Models.Sponsor

<h2>Chi tiết nhà tài trợ</h2>

<dl class="row">
    <dt class="col-sm-2">Tên</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Ngành nghề</dt>
    <dd class="col-sm-10">@Model.Industry</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Sửa</a>
<a asp-action="Index" class="btn btn-secondary">Quay lại</a>