<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Sports Tournament Manager</title>
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" 
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">🏆 Sports Tournament Manager</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" 
                    data-bs-target="#navbarNav" aria-controls="navbarNav" 
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (User?.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Teams" asp-action="Index">Teams</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Players" asp-action="Index">Players</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Coaches" asp-action="Index">Coaches</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Disciplines" asp-action="Index">Disciplines</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Tournaments" asp-action="Index">Tournaments</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Matches" asp-action="Index">Matches</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Sponsors" asp-action="Index">Sponsors</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Venues" asp-action="Index">Venues</a></li>
                    }
                </ul>

                <ul class="navbar-nav ms-auto">
                    @if (User?.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="navbar-text text-light">Xin chào, @User.Identity.Name</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger fw-bold" asp-controller="Accounts" asp-action="Logout">Đăng xuất</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Accounts" asp-action="Login">Đăng nhập</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Accounts" asp-action="Register">Đăng ký</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="bg-dark text-light text-center py-3 mt-4">
        &copy; 2026 - Sports Tournament Manager
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/layout.js"></script>
</body>
</html>