@model SportsTournamentManager.Models.Coach

<h2>Xóa HLV</h2>

<h4>Bạn có chắc muốn xóa HLV này?</h4>
<hr />

<dl class="row">
    <dt class="col-sm-2">Tên</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Quốc tịch</dt>
    <dd class="col-sm-10">@Model.Nationality</dd>

    <dt class="col-sm-2">Đội</dt>
    <dd class="col-sm-10">@Model.Team?.Name</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>