@model IEnumerable<SportsTournamentManager.Models.Match>

<h2>Danh sách trận đấu</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Thêm trận đấu mới</a>
</p>

@if (TempData["Message"] != null)
{
    <script>
        alert('@Html.Raw(TempData["Message"])');
    </script>
}

<table class="table">
    <thead>
        <tr>
            <th>Ngày</th>
            <th>Giải đấu</th>
            <th>Đội A</th>
            <th>Đội B</th>
            <th>Tỉ số</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var match in Model)
    {
        <tr>
            <td>@match.Date.ToString("dd/MM/yyyy")</td>
            <td>@match.Tournament?.Name</td>
            <td>@match.TeamA?.Name</td>
            <td>@match.TeamB?.Name</td>
            <td>@match.ScoreA - @match.ScoreB</td>
            <td>
                <a asp-action="Edit" asp-route-id="@match.Id" class="btn btn-primary">Sửa</a>
                <a asp-action="Details" asp-route-id="@match.Id" class="btn btn-info">Chi tiết</a>
                <a asp-action="Delete" asp-route-id="@match.Id" class="btn btn-danger">Xóa</a>
            </td>
        </tr>
    }
    </tbody>
</table>