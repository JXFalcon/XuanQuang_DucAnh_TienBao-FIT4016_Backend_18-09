@model IEnumerable<SportsTournamentManager.Models.Discipline>

<h2>Danh sách môn thi đấu</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-success">Thêm môn mới</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Tên môn</th>
            <th>Loại bộ môn</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var d in Model)
    {
        <tr>
            <td>@d.Name</td>
            <td>@d.Type</td>
            <td>
                <a asp-action="Edit" asp-route-id="@d.Id" class="btn btn-primary">Sửa</a>
                <a asp-action="Details" asp-route-id="@d.Id" class="btn btn-info">Chi tiết</a>
                <a asp-action="Delete" asp-route-id="@d.Id" class="btn btn-danger">Xóa</a>
            </td>
        </tr>
    }
    </tbody>
</table>