@model IEnumerable<SportsTournamentManager.Models.Tournament>

<h2>Danh sách giải đấu</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-success">Thêm giải mới</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Tên giải</th>
            <th>Loại</th>
            <th>Ngày bắt đầu</th>
            <th>Ngày kết thúc</th>
            <th>Môn</th>
            <th>Địa điểm</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var t in Model)
    {
        <tr>
            <td>@t.Name</td>
            <td>@t.Type</td>
            <td>@t.StartDate.ToString("dd/MM/yyyy")</td>
            <td>@t.EndDate.ToString("dd/MM/yyyy")</td>
            <td>@t.Discipline?.Name</td>
            <td>@t.Venue?.Name</td>
            <td>
                <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-primary">Sửa</a>
                <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-info">Chi tiết</a>
                <a asp-action="Delete" asp-route-id="@t.Id" class="btn btn-danger">Xóa</a>
            </td>
        </tr>
    }
    </tbody>
</table>