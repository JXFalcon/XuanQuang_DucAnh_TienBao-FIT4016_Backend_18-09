@model SportsTournamentManager.Models.Tournament

<h2>Xóa giải đấu</h2>

<h4>Bạn có chắc muốn xóa giải này?</h4>
<hr />

<dl class="row">
    <dt class="col-sm-2">Tên giải</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Loại</dt>
    <dd class="col-sm-10">@Model.Type</dd>

    <dt class="col-sm-2">Ngày bắt đầu</dt>
    <dd class="col-sm-10">@Model.StartDate.ToString("dd/MM/yyyy")</dd>

    <dt class="col-sm-2">Ngày kết thúc</dt>
    <dd class="col-sm-10">@Model.EndDate.ToString("dd/MM/yyyy")</dd>

    <dt class="col-sm-2">Môn thi đấu</dt>
    <dd class="col-sm-10">@Model.Discipline?.Name</dd>

    <dt class="col-sm-2">Địa điểm</dt>
    <dd class="col-sm-10">@Model.Venue?.Name</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>